# Google Gemini (LLM + embeddings)
GEMINI_API_KEY=
# Weaviate (Docker local par défaut)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080

OPENAI_API_KEY=
# Backend d'agent : rag_pipeline | elysia
AGENT_BACKEND=rag_pipeline
# Modèle de génération OpenAI
LLM_MODEL=gpt-4.1
# Alternatives : gpt-4o, gpt-4o-mini

# Modèle d'embedding OpenAI
EMBEDDING_MODEL=text-embedding-3-large
# Alternatives : text-embedding-3-small (1536 dims), text-embedding-ada-002 (1536 dims)

# Nombre de résultats hybrides envoyés au LLM
TOP_K_FINAL=10

# Pondération hybrid : 0.0 = BM25 pur, 1.0 = dense pur, 0.5 = équilibré
HYBRID_ALPHA=0.5

MAX_TOKENS=1000
