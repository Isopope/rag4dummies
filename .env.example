# Google Gemini (LLM + embeddings)
GEMINI_API_KEY=
# Weaviate (Docker local par défaut)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080

OPENAI_API_KEY=
# Backend d'agent : rag_pipeline | elysia
AGENT_BACKEND=rag_pipeline
# Modèle de génération OpenAI
LLM_MODEL=gpt-4.1
# Alternatives : gpt-4o, gpt-4o-mini

# Modèle d'embedding OpenAI
EMBEDDING_MODEL=text-embedding-3-large
# Alternatives : text-embedding-3-small (1536 dims), text-embedding-ada-002 (1536 dims)

# Nombre de résultats hybrides envoyés au LLM
TOP_K_FINAL=10

# Pondération hybrid : 0.0 = BM25 pur, 1.0 = dense pur, 0.5 = équilibré
HYBRID_ALPHA=0.5

MAX_TOKENS=1000

# ── API FastAPI ────────────────────────────────────────────────────────────────
# Hôte et port du serveur uvicorn
API_HOST=0.0.0.0
API_PORT=8000

# Origines autorisées pour CORS (séparées par des virgules, * = toutes)
# En production, restreindre aux domaines autorisés : https://app.example.com
CORS_ORIGINS=*

# Reranking Cohere (optionnel)
# COHERE_API_KEY=

# ── Base de données ────────────────────────────────────────────────────────────
# SQLite (développement / tests) — créé automatiquement au démarrage
DATABASE_URL=sqlite+aiosqlite:///./rag.db
# PostgreSQL (production) :
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ragdb
# Activer les logs SQL (true | false)
DB_ECHO=false

# ── Object Storage MinIO / S3 (visual grounding — PDF source) ─────────────────
# Laisser MINIO_ENDPOINT vide pour utiliser le stockage local (./uploads/)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-documents
# true = HTTPS (production), false = HTTP (dev local)
MINIO_SECURE=false
# Durée de validité des presigned URLs en secondes (défaut : 3600 = 1h)
MINIO_PRESIGN_EXPIRES=3600

# ── Celery / Redis (ingestion asynchrone) ─────────────────────────────────────
# Redis broker (base 0) + result backend (base 1)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Concurrence des workers (défaut : 2 pour l'ingestion lourde)
CELERY_WORKER_INGEST_CONCURRENCY=2
CELERY_WORKER_LIGHT_CONCURRENCY=4
# Durée max d'une tâche d'ingestion en secondes (défaut : 1800 = 30 min)
CELERY_INGEST_SOFT_TIMEOUT=1800
